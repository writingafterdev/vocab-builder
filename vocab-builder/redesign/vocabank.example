<span class="material-symbols-outlined text-primary text-[32px]">book_2</span>
</div>
<h1 class="text-3xl font-bold text-[#111318] dark:text-white tracking-tight">All Words</h1>
</div>
<p class="text-[#616f89] dark:text-gray-400 text-sm ml-[60px]">Manage your entire vocabulary collection, track progress, and review context.</p>
</div>
<div class="flex flex-col sm:flex-row justify-between items-end sm:items-center gap-4 border-b border-[#e5e7eb] dark:border-[#1f2937]">
<div class="flex gap-6 -mb-[1px]">
<button class="group flex items-center gap-2 pb-3 border-b-2 border-primary text-primary dark:text-white font-medium text-sm">
<span class="material-symbols-outlined text-[18px]" data-weight="fill">table_chart</span>
