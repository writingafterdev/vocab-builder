                </button>
</div>
<div class="flex items-center gap-2 pb-2">
<button class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-primary hover:bg-primary/10 rounded-md border border-transparent transition-colors mr-2">
<span class="material-symbols-outlined text-[18px]">play_circle</span>
                    Start Selection Review
                </button>
<div class="h-4 w-[1px] bg-gray-300 dark:bg-gray-700 mx-1"></div>
