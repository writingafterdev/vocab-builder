<span class="material-symbols-outlined text-[18px]">filter_list</span>
                    Filter
                </button>
<button class="flex items-center gap-1.5 px-2 py-1 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 rounded transition-colors">
<span class="material-symbols-outlined text-[18px]">sort</span>
                    Sort
                </button>
<button class="flex items-center gap-1.5 px-2 py-1 text-sm text-primary hover:bg-primary/10 rounded transition-colors ml-2">
<span class="material-symbols-outlined text-[18px]">add</span>
