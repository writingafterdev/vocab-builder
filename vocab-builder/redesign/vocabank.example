<div class="flex items-center gap-3 relative">
<input class="w-4 h-4 text-primary bg-gray-100 border-gray-300 rounded focus:ring-primary dark:focus:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600 opacity-0 group-hover:opacity-100 transition-opacity" type="checkbox"/>
<div class="flex items-center gap-1">
<button class="w-6 h-6 flex items-center justify-center rounded hover:bg-black/10 dark:hover:bg-white/10 text-gray-500 transition-colors">
<span class="material-symbols-outlined text-[22px]">arrow_drop_down</span>
</button>
<span class="font-bold text-[#111318] dark:text-white">Grow</span>
<span class="ml-2 px-1.5 py-0.5 rounded text-[10px] font-bold bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300">2</span>
