<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>VocabBuilder Library</title>
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Theme Configuration -->
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#135bec",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                        "card-light": "#ffffff",
                        "card-dark": "#1A202C",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "1rem",
                        "xl": "1.5rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style>
        body {
            font-family: 'Inter', sans-serif;
        }
        /* Hide scrollbar for Chrome, Safari and Opera */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        /* Hide scrollbar for IE, Edge and Firefox */
        .no-scrollbar {
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white overflow-hidden h-screen flex flex-col">
<!-- Top Navigation (Mobile only usually, but good for structure if we collapse sidebar) -->
<!-- For this desktop design, we use a main layout container -->
<div class="flex h-full w-full max-w-[1600px] mx-auto">
<!-- Left Sidebar -->
<aside class="w-64 h-full hidden lg:flex flex-col border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-card-dark shrink-0">
<div class="p-6">
<div class="flex items-center gap-2 mb-8">
<div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white font-bold text-xl">V</div>
<h1 class="text-lg font-bold tracking-tight">VocabBuilder</h1>
</div>
<div class="flex flex-col gap-2">
<div class="px-3 py-2">
<p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">User Workspace</p>
</div>
<a class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-primary/10 text-primary" href="#">
<span class="material-symbols-outlined" style="font-size: 24px;">book_2</span>
<p class="text-sm font-medium">Library</p>
</a>
<a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" href="#">
<span class="material-symbols-outlined" style="font-size: 24px;">account_balance</span>
<p class="text-sm font-medium">Vocabulary Bank</p>
</a>
<a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" href="#">
<span class="material-symbols-outlined" style="font-size: 24px;">folder_open</span>
<p class="text-sm font-medium">Collections</p>
</a>
<a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" href="#">
<span class="material-symbols-outlined" style="font-size: 24px;">settings</span>
<p class="text-sm font-medium">Settings</p>
</a>
</div>
</div>
<div class="mt-auto p-6 border-t border-slate-200 dark:border-slate-800">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-slate-200 overflow-hidden">
<img alt="User Profile Avatar" class="w-full h-full object-cover" data-alt="User profile picture of a smiling man" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_tusvWgBcfkMt04V7LUwKidUiIZMFYGoX1UE1RbAynAWAX3x3kKFs-oM3Y9BwzElP5nNxR-reHzIkNj5R0P5HEbmQ43-zoH-jldFyOOg_2AVYA8Gl0oOyxccJVlUP5uVkJPHKVs-piNYMNGV4y7q2gWlZanlU5qR5HbDhidENrrAeHmUaX63l_7-3Z4_wAe_kqrxivKRIt4OTs5ci3JMK5CwOI10S8OMJtpw28FvE8-R86LVlXBP7fnWVxB_FVZsfxQOY1utUJ9Q"/>
</div>
<div class="flex flex-col">
<p class="text-sm font-medium text-slate-900 dark:text-white">Alex Morgan</p>
<p class="text-xs text-slate-500">Premium Plan</p>
</div>
</div>
</div>
</aside>
<!-- Main Feed Area -->
<main class="flex-1 h-full overflow-y-auto bg-background-light dark:bg-background-dark relative scroll-smooth no-scrollbar">
<div class="max-w-[720px] mx-auto py-8 px-4 lg:px-8 pb-32">
<!-- Page Heading & Actions -->
<div class="mb-8">
<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
<div>
<h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight mb-2">Library</h1>
<p class="text-slate-500 dark:text-slate-400">Manage your reading materials and saved vocabulary.</p>
</div>
<button class="flex items-center justify-center gap-2 bg-primary hover:bg-blue-600 text-white px-5 py-2.5 rounded-xl font-bold shadow-lg shadow-blue-500/20 transition-all active:scale-95 whitespace-nowrap">
<span class="material-symbols-outlined text-[20px]">add</span>
<span>Import Material</span>
</button>
</div>
<!-- Search Bar -->
<div class="relative group mb-6">
<div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">search</span>
</div>
<input class="block w-full pl-11 pr-4 py-3.5 bg-white dark:bg-card-dark border-0 rounded-xl text-slate-900 dark:text-white shadow-sm ring-1 ring-slate-200 dark:ring-slate-700 placeholder:text-slate-400 focus:ring-2 focus:ring-primary sm:text-sm sm:leading-6 transition-shadow" placeholder="Search titles, authors, or snippets..." type="text"/>
</div>
<!-- Filter Chips -->
<div class="flex gap-2 overflow-x-auto pb-2 no-scrollbar">
<button class="bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-colors">All</button>
<button class="bg-white dark:bg-card-dark border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">Books</button>
<button class="bg-white dark:bg-card-dark border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">Articles</button>
<button class="bg-white dark:bg-card-dark border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">News</button>
<button class="bg-white dark:bg-card-dark border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">Unread</button>
</div>
</div>
<!-- Feed Stream -->
<div class="flex flex-col gap-6">
<!-- Card 1: Article (Active Reading) -->
<article class="group bg-white dark:bg-card-dark rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-800 hover:shadow-md transition-all duration-200">
<!-- Header -->
<div class="flex justify-between items-start mb-3">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center overflow-hidden">
<img alt="Medium Logo" class="w-6 h-6 object-contain opacity-70" data-alt="Medium website logo monogram" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDoJW20CTeNtweU7OhqZw0oXuiweBBgsWkZpJAQLcw_vmyqruwMUIANVlE_1aOknSX6JyAsVJles7_J_d9gg_f4UESih5kANX2l1pDAGs6Jk3KjnxLeO1fxWXgRQRhjCQeH3143wA_UH3bXy8NQYspGK3T3eF4qzdYe7xzPFveuR3FlK2ZH5j9QcmnpKIcpLlC022Immm7jha4bnVrRtnGVHEkcLQy-2aoZWJq0GFFdqa1brsd_ddp4WDxFElTH-1QpXDTSOe56Vj0"/>
</div>
<div>
<h3 class="text-sm font-semibold text-slate-900 dark:text-white">Medium</h3>
<div class="flex items-center gap-2 text-xs text-slate-500">
<span>Cassie Kozyrkov</span>
<span class="w-0.5 h-0.5 rounded-full bg-slate-400"></span>
<span>2 hours ago</span>
</div>
</div>
</div>
<button class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 p-1 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
<span class="material-symbols-outlined">more_horiz</span>
</button>
</div>
<!-- Body -->
<div class="flex gap-4 mb-4">
<div class="flex-1">
<h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2 leading-tight group-hover:text-primary transition-colors cursor-pointer">The AI Revolution: Why Vocabulary Matters More Than Ever</h2>
<p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-3">
                                    As artificial intelligence reshapes how we communicate, the precision of our language becomes our most valuable asset. Understanding nuance isn't just about sounding smart—it's about effective prompting and clear thinking...
                                </p>
</div>
<div class="hidden sm:block w-24 h-24 shrink-0 rounded-lg bg-slate-100 dark:bg-slate-800 overflow-hidden">
<img alt="Article Thumbnail" class="w-full h-full object-cover" data-alt="Abstract colorful AI generated digital wave art" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDARoXPDyBZ_P4GuPjtRrB0ugmr7mjCdZIYaPj0Oi7L5tltI3qcaEGTiVYXOmY5fLpOCUw2uya3KLY3qvhcrwdiwhB9Qss683_eXF1COxgPJQOWvDFCZIu85WzIQzN9crm7aeh2y8IIYT5yLftRORivKHje0DDDGjEnkhjF2EyYKrBQw57qQRg9onw_GE6Tw3fzooIP3IlcB5qTHmfDubGmDR4oqqiSY3coWZR66x-OkvGXvyakB3KwWHdnfTJHB-hhaw9s_5NcbMY"/>
</div>
</div>
<!-- Tags/Meta -->
<div class="flex items-center gap-2 mb-4">
<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
                                Technology
                            </span>
<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400">
                                ~1200 words
                            </span>
</div>
<!-- Footer / Actions -->
<div class="pt-4 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
<div class="flex items-center gap-6">
<div class="flex flex-col gap-1 w-32">
<div class="flex justify-between text-[10px] font-medium text-slate-500 uppercase tracking-wide">
<span>Progress</span>
<span>45%</span>
</div>
<div class="h-1.5 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full w-[45%]"></div>
</div>
</div>
<div class="flex items-center gap-1.5 text-slate-600 dark:text-slate-300 text-sm font-medium" title="Saved Words">
<span class="material-symbols-outlined text-[18px] text-primary">bookmark</span>
<span>12</span>
</div>
</div>
<div class="flex items-center gap-2">
<button class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors" title="Archive">
<span class="material-symbols-outlined text-[20px]">archive</span>
</button>
<button class="px-4 py-2 bg-primary/10 hover:bg-primary/20 text-primary rounded-lg text-sm font-bold transition-colors">
                                    Continue
                                </button>
</div>
</div>
</article>
<!-- Card 2: Book (New) -->
<article class="group bg-white dark:bg-card-dark rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-800 hover:shadow-md transition-all duration-200">
<div class="flex justify-between items-start mb-3">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-lg bg-orange-100 dark:bg-orange-900/20 flex items-center justify-center text-orange-600 dark:text-orange-400">
<span class="material-symbols-outlined">menu_book</span>
</div>
<div>
<h3 class="text-sm font-semibold text-slate-900 dark:text-white">EPUB Import</h3>
<div class="flex items-center gap-2 text-xs text-slate-500">
<span>Morgan Housel</span>
<span class="w-0.5 h-0.5 rounded-full bg-slate-400"></span>
<span>Yesterday</span>
</div>
</div>
</div>
<button class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 p-1 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
<span class="material-symbols-outlined">more_horiz</span>
</button>
</div>
<div class="flex gap-4 mb-4">
<div class="w-16 h-24 shrink-0 rounded shadow-sm overflow-hidden bg-slate-200">
<img alt="Book Cover" class="w-full h-full object-cover" data-alt="Cover of a hardcover book with beige spine" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAk0tYUmPF8YsSRZXJYde3v3e1Sbji9xg5T8N0sLU3B8124KVxRZsk9tLED7D-FgAsI8Co7GI4zHKYFJ-z9Y9hR67VL8P-_szLE2weALobb8doCQJP9IdBtGe9SpcVRaYMahwBkOhKU8PcT2L_cPJFdvYuC8uc8Z-Vs3x5T0LZTC_o4xufaR-D0t7oohTaQ51dq6ulvd6fEBEnjPCRnncT-NXTZ6pinkUMVQSvnJh5Xi6ce3E_s3PSjNqgIpxiK6xyYXJxwLe9V9UQ"/>
</div>
<div class="flex-1">
<h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2 leading-tight group-hover:text-primary transition-colors cursor-pointer">The Psychology of Money</h2>
<p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-2">
                                    Doing well with money isn’t necessarily about what you know. It’s about how you behave. And behavior is hard to teach, even to really smart people...
                                </p>
</div>
</div>
<div class="pt-4 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
<div class="flex items-center gap-6">
<div class="flex flex-col gap-1 w-32">
<div class="flex justify-between text-[10px] font-medium text-slate-500 uppercase tracking-wide">
<span>Progress</span>
<span>0%</span>
</div>
<div class="h-1.5 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full w-[0%]"></div>
</div>
</div>
<div class="flex items-center gap-1.5 text-slate-400 text-sm font-medium" title="Saved Words">
<span class="material-symbols-outlined text-[18px]">bookmark_border</span>
<span>0</span>
</div>
</div>
<div class="flex items-center gap-2">
<button class="px-4 py-2 bg-primary hover:bg-blue-600 text-white rounded-lg text-sm font-bold shadow-md shadow-blue-500/20 transition-all">
                                    Start Reading
                                </button>
</div>
</div>
</article>
<!-- Card 3: News (Completed) -->
<article class="group bg-white dark:bg-card-dark rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-800 hover:shadow-md transition-all duration-200 opacity-80 hover:opacity-100">
<div class="flex justify-between items-start mb-3">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-lg bg-red-50 dark:bg-red-900/20 flex items-center justify-center overflow-hidden">
<span class="font-serif font-black text-red-700 dark:text-red-400">NYT</span>
</div>
<div>
<h3 class="text-sm font-semibold text-slate-900 dark:text-white">The New York Times</h3>
<div class="flex items-center gap-2 text-xs text-slate-500">
<span>Science Desk</span>
<span class="w-0.5 h-0.5 rounded-full bg-slate-400"></span>
<span>3 days ago</span>
</div>
</div>
</div>
<div class="flex items-center gap-2">
<span class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 text-xs font-bold px-2 py-1 rounded-md flex items-center gap-1">
<span class="material-symbols-outlined text-[14px]">check</span>
                                    Read
                                </span>
<button class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 p-1 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
<span class="material-symbols-outlined">more_horiz</span>
</button>
</div>
</div>
<div class="flex gap-4 mb-4">
<div class="flex-1">
<h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2 leading-tight group-hover:text-primary transition-colors cursor-pointer">James Webb Telescope Discovers New Galaxies</h2>
<p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-2">
                                    The images reveal structures from the early universe that shouldn't exist according to our current models of cosmology. This finding challenges...
                                </p>
</div>
</div>
<div class="pt-4 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
<div class="flex items-center gap-6">
<div class="flex flex-col gap-1 w-32">
<div class="flex justify-between text-[10px] font-medium text-slate-500 uppercase tracking-wide">
<span>Progress</span>
<span>100%</span>
</div>
<div class="h-1.5 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
<div class="h-full bg-green-500 rounded-full w-full"></div>
</div>
</div>
<div class="flex items-center gap-1.5 text-slate-600 dark:text-slate-300 text-sm font-medium" title="Saved Words">
<span class="material-symbols-outlined text-[18px] text-primary">bookmark</span>
<span>5</span>
</div>
</div>
<div class="flex items-center gap-2">
<button class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors" title="Review">
<span class="material-symbols-outlined text-[20px]">restart_alt</span>
</button>
</div>
</div>
</article>
<!-- Infinite Scroll Loader -->
<div class="py-8 flex justify-center">
<div class="flex items-center gap-2 text-slate-400">
<div class="w-2 h-2 rounded-full bg-slate-300 animate-bounce"></div>
<div class="w-2 h-2 rounded-full bg-slate-300 animate-bounce delay-100"></div>
<div class="w-2 h-2 rounded-full bg-slate-300 animate-bounce delay-200"></div>
</div>
</div>
</div>
</div>
<!-- Floating Action Button (Mobile/Tablet usually, but useful here too) -->
<button class="absolute bottom-8 right-8 lg:hidden w-14 h-14 bg-primary text-white rounded-full shadow-xl shadow-blue-500/30 flex items-center justify-center hover:scale-105 transition-transform z-10">
<span class="material-symbols-outlined text-3xl">add</span>
</button>
</main>
<!-- Right Sidebar (Widgets) -->
<aside class="w-80 h-full hidden xl:flex flex-col p-6 gap-6 bg-background-light dark:bg-background-dark shrink-0">
<!-- Daily Goal Widget -->
<div class="bg-white dark:bg-card-dark rounded-xl p-5 shadow-sm border border-slate-200 dark:border-slate-800">
<div class="flex items-center justify-between mb-4">
<h3 class="font-bold text-slate-900 dark:text-white">Daily Goal</h3>
<span class="text-xs font-semibold text-primary bg-primary/10 px-2 py-1 rounded">Level 3</span>
</div>
<div class="relative w-32 h-32 mx-auto mb-4 flex items-center justify-center">
<svg class="transform -rotate-90 w-full h-full">
<circle class="text-slate-100 dark:text-slate-800" cx="64" cy="64" fill="transparent" r="56" stroke="currentColor" stroke-width="8"></circle>
<circle class="text-primary" cx="64" cy="64" fill="transparent" r="56" stroke="currentColor" stroke-dasharray="351.85" stroke-dashoffset="100" stroke-linecap="round" stroke-width="8"></circle>
</svg>
<div class="absolute inset-0 flex flex-col items-center justify-center">
<span class="text-3xl font-black text-slate-900 dark:text-white">12</span>
<span class="text-xs text-slate-500 uppercase font-bold">Words</span>
</div>
</div>
<p class="text-center text-sm text-slate-600 dark:text-slate-400">
                    You're 70% towards your daily goal of learning 15 new words!
                </p>
</div>
<!-- Review Due Widget -->
<div class="bg-white dark:bg-card-dark rounded-xl p-5 shadow-sm border border-slate-200 dark:border-slate-800">
<div class="flex items-center justify-between mb-3">
<h3 class="font-bold text-slate-900 dark:text-white">Review Due</h3>
<span class="w-2 h-2 rounded-full bg-red-500"></span>
</div>
<div class="flex items-center gap-3 mb-4">
<div class="bg-orange-50 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400 p-3 rounded-lg">
<span class="material-symbols-outlined">style</span>
</div>
<div>
<p class="text-2xl font-bold text-slate-900 dark:text-white">45</p>
<p class="text-xs text-slate-500">Cards ready for review</p>
</div>
</div>
<button class="w-full py-2 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-lg text-sm font-bold hover:opacity-90 transition-opacity">
                    Start Review Session
                </button>
</div>
<!-- Trending Topics -->
<div class="bg-transparent rounded-xl p-1">
<h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Trending Collections</h3>
<div class="flex flex-col gap-3">
<div class="flex items-center gap-3 group cursor-pointer">
<div class="w-8 h-8 rounded bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400 group-hover:border-primary group-hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[18px]">tag</span>
