rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuth() && request.auth.token.email == 'ducanhcontactonfb@gmail.com';
    }
    
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      
      match /savedPhrases/{phraseId} {
        allow read, write: if true;
      }

      match /practiceHistory/{historyId} {
        allow read, write: if true;
      }

      match /journeyNodes/{nodeId} {
        allow read, write: if true;
      }
    }
    
    match /savedPhrases/{phraseId} {
      allow read, create, update: if true;
      allow delete: if true;
    }
    
    match /scenarios/{scenarioId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    
    match /tokenUsage/{usageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }
    
    match /topics/{topicId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    
    match /articleSaves/{saveId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    
    match /savedArticles/{saveId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    
    match /commentLikes/{likeId} {
      allow read: if true;
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    
    match /reposts/{repostId} {
      allow read: if true;
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    
    match /debates/{debateId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    
    match /userReadingLists/{listId} {
      allow read, create, update: if true;
      allow delete: if true;
    }
    
    match /readingSessions/{sessionId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    
    match /phraseDictionary/{phraseId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }
    
    match /questionBank/{questionId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /completedSessions/{sessionId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /liveSessions/{sessionId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /userWeaknesses/{userId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /userMilestones/{userId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /openEndedSessions/{sessionId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /turnBasedSessions/{sessionId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
    
    match /favorite_quotes/{docId} {
      allow read, write: if true;
    }

    match /importSources/{sourceId} {
      allow read, create, update: if true;
      allow delete: if true;
    }

    match /batchJobs/{jobId} {
      allow read, write: if true;
    }

    match /preGeneratedExercises/{docId} {
      allow read, write: if true;
    }

    match /generatedQuotes/{docId} {
      allow read, write: if true;
    }

    match /generatedSessions/{sessionId} {
      allow read, write: if true;
    }

    match /feedQuizzes/{docId} {
      allow read, write: if true;
    }

    match /quotes/{quoteId} {
      allow read, write: if true;
    }

    match /quote_feed_state/{stateId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}