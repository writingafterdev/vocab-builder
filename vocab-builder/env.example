# ===================================
# VOCAB BUILDER - Environment Variables
# ===================================

# Firebase Configuration (Required)
# Get from: https://console.firebase.google.com → Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ===================================
# AI API Keys
# ===================================

# Alibaba Cloud DashScope (QWEN Model) - For quick, cheap tasks
# Get from: https://dashscope.console.aliyun.com/
# Used for: Meaning lookup, Exercise generation, Phrase extraction
# Model: qwen-flash
# Cost: ~$0.05/M input, $0.40/M output
DASHSCOPE_API_KEY=sk-...

# Gemini 2.0 Flash - For content generation
# Get from: https://aistudio.google.com/app/apikey
# Used for: Translation, Content generation from saved phrases
# Cost: ~$1/M input, $3/M output
GEMINI_API_KEY=your_gemini_api_key

# ===================================
# Admin Configuration
# ===================================

# Admin emails (comma-separated list)
# These users get access to /admin page
ADMIN_EMAILS=youremail@example.com

ONCE_FOR_ALL=sk-19162acfcd6a47ae84e208c203bbf679
